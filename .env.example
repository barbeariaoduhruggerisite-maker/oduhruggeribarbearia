# ODuh Ruggeri Barbearia — Variaveis de Ambiente
# ──────────────────────────────────────────────────────────
# Copie este arquivo para .env.local e preencha com os valores
# reais do seu projeto Supabase. NUNCA commite .env.local!
#
# Como obter estes valores:
#   1. Acesse https://supabase.com e crie um projeto gratuito
#   2. Va em Project Settings > API
#   3. Copie "Project URL" e "anon public" key
# ──────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://SEU_PROJETO_ID.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_public_key_aqui
